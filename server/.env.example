NODE_ENV=development
PORT=4000

# MySQL (matches infra/docker-compose.yml)
DATABASE_URL=mysql://kbc:kbc_secret@localhost:3306/kbc

# JWT
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Logging
LOG_LEVEL=info

# Google Play Billing (server-side receipt verification)
GOOGLE_PLAY_PACKAGE_NAME=com.ishan.kbc
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=./secrets/play-console.json
